# Copy to deploy/opal/dev-secrets.env via ./scripts/generate-opal-dev-secrets.sh
# Never commit dev-secrets.env or deploy/opal/keys/

OPAL_AUTH_MASTER_TOKEN=replace-me
OPAL_POLICY_REPO_WEBHOOK_SECRET=replace-me
OPAL_POLICY_REPO_POLLING_INTERVAL=300
CHEX_OPAL_SECURE=1

# Generated by generate-opal-dev-secrets.sh (private key newlines as underscores):
# OPAL_AUTH_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----_...
# OPAL_AUTH_PUBLIC_KEY=ssh-rsa AAAA...
